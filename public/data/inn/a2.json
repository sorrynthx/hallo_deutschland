    "conversation": [
      {
        "id": "conv_inn_a2_W11_001",
        "situation": "손님이 뭔가를 주문하고 싶어하면 웨이터가 주문을 받습니다. 웨이터는 요리에 어떤 반찬이 있는지 묻습니다.",
        "situation_icon": "🍽️",
        "dialogue": [
          {
            "role": "Gast",
            "text": "Entschuldigen Sie, könnten wir bitte die Speisekarte haben?",
            "pronunciation": "Ent-shul-di-gen zee, kœn-ten veer bit-te dee shpai-ze-kar-te ha-ben?",
            "translation": "죄송한데 메뉴 좀 주시겠어요?",
            "isQuestion": false
          },
          {
            "role": "Kellner",
            "text": "Ja, natürlich, hier ist sie. Was möchten Sie trinken?",
            "pronunciation": "Ya, na-tuer-lich, heer ist zee. Vas mœch-ten zee trin-ken?",
            "translation": "예, 물론입니다. 여기 있습니다. 무엇을 마시고 싶나요?",
            "isQuestion": false
          },
          {
            "role": "Gast",
            "text": "Ich hätte gerne ein großes Bier und dann die Schweinshaxe.",
            "pronunciation": "Ish het-te gern ai-n gro-ses beer unt dan dee shvainz-hak-se.",
            "translation": "나는 큰 맥주를 마시고 그 다음에는 돼지 족발을 먹고 싶습니다.",
            "isQuestion": false
          },
          {
            "role": "Kellner",
            "text": "Die Schweinshaxe. Möchten Sie dazu Kartoffelklöße oder Bratkartoffeln?",
            "pronunciation": "Dee shvainz-hak-se. Mœch-ten zee da-tsoo kar-tof-fel-klœ-se o-der brat-kar-tof-feln?",
            "translation": "돼지 뒷다리. 감자 만두나 감자튀김을 함께 드시겠어요?",
            "isQuestion": true
          }
        ],
        "choices": [
          {
            "text": "Ich nehme die Pommes.",
            "pronunciation": "Ish nay-me dee pom-mes.",
            "translation": "감자튀김은 제가 가져갈게요."
          },
          {
            "text": "Ich hätte gern die Kartoffelklöße.",
            "pronunciation": "Ish het-te gern dee kar-tof-fel-klœ-se.",
            "translation": "저는 감자 만두를 먹고 싶습니다."
          },
          {
            "text": "Ich möchte keinen Salat.",
            "pronunciation": "Ish mœch-te kai-nen sa-lat.",
            "translation": "나는 샐러드를 원하지 않습니다."
          }
        ],
        "answer": "Ich hätte gern die Kartoffelklöße.",
        "explanation": "웨이터가 돼지갈비 반찬에 대해 묻습니다. '감자만두'는 손님이 선택할 수 있는 옵션 중 하나다.",
        "grammar_point": "Dativ nach Präposition 'dazu' und Akkusativ bei 'möchten'.",
        "week": "W11"
      },
      {
        "id": "conv_inn_a2_W11_002",
        "situation": "손님이 식사를 하고 돈을 지불하려고 합니다. 웨이터가 결제 방법을 묻습니다.",
        "situation_icon": "💶",
        "dialogue": [
          {
            "role": "Gast",
            "text": "Entschuldigen Sie, könnten wir bitte bezahlen?",
            "pronunciation": "Ent-shul-di-gen zee, kœn-ten veer bit-te be-tsah-len?",
            "translation": "죄송합니다. 결제해 주시겠어요?",
            "isQuestion": false
          },
          {
            "role": "Kellner",
            "text": "Ja, natürlich. War alles in Ordnung?",
            "pronunciation": "Ya, na-tuer-lich. Var al-les in ord-nung?",
