    "conversation": [
      {
        "id": "conv_rathaus_b1_W11_001",
        "situation": "귀하는 이 도시에 처음 오셨고 시민등록사무소에 주소를 등록하셔야 합니다.",
        "situation_icon": "🏠",
        "dialogue": [
          {
            "role": "Bürger/in",
            "text": "Guten Tag, ich möchte mich gerne anmelden.",
            "pronunciation": "/ˌɡuːtn̩ taːk, ɪç mœçtə mɪç ˈɡɛʁnə ˈanmɛldn̩/",
            "translation": "안녕하세요. 등록하고 싶습니다.",
            "isQuestion": false
          },
          {
            "role": "Beamter/in",
            "text": "Guten Tag. Haben Sie einen Termin?",
            "pronunciation": "/ˌɡuːtn̩ taːk. ˈhabm̩ ziː ˈaɪ̯nən tɛʁˈmiːn/",
            "translation": "안녕하세요. 약속이 있나요?",
            "isQuestion": false
          },
          {
            "role": "Bürger/in",
            "text": "Nein, leider nicht. Ist es auch ohne Termin möglich?",
            "pronunciation": "/naɪ̯n, ˈlaɪ̯dəʁ nɪçt. ɪst ɛs aʊ̯x ˈoːnə tɛʁˈmiːn ˈmøːklɪç/",
            "translation": "아니요, 안타깝게도 그렇지 않습니다. 예약 없이도 가능한가요?",
            "isQuestion": false
          },
          {
            "role": "Beamter/in",
            "text": "Normalerweise braucht man einen Termin. Aber ausnahmsweise ist heute noch etwas frei. Wir können das jetzt erledigen, wenn Sie möchten. Dazu brauche ich Ihren Personalausweis und die Wohnungsgeberbestätigung. Haben Sie diese Dokumente dabei?",
            "pronunciation": "/nɔʁˈmaːləʁvaɪ̯zə braʊ̯xt man ˈaɪ̯nən tɛʁˈmiːn. ˈabɐ aʊ̯snaːmsˌvaɪ̯zə ɪst ˈhɔɪ̯tə nɔx ˈɛtvas fraɪ̯. viːɐ̯ kœnən das jɛt͡st ɛɐ̯ˈleːdɪɡn̩, vɛn ziː ˈmœçtn̩. daˈt͡suː braʊ̯x ɪç ˈiːʁən pɛʁzoˈnaːlˌaʊ̯svaɪ̯s ʊnt diː ˈvoːnʊŋsˌɡeːbɐbɛˌʃtɛːtɪɡʊŋ. ˈhabm̩ ziː ˈdiːzə dokuˈmɛntə daˈbaɪ̯?/",
            "translation": "일반적으로 약속이 필요합니다. 하지만 예외적으로 오늘날에도 여전히 무료인 것이 있습니다. 원한다면 지금 할 수 있습니다. 그러기 위해서는 귀하의 신분증과 집주인의 거주 확인서가 필요합니다. 이 서류를 가지고 있나요?",
            "isQuestion": true
          }
        ],
        "choices": [
          {
            "text": "Ja, die habe ich dabei.",
            "pronunciation": "/jaː, diː ˈhabə ɪç daˈbaɪ̯/",
            "translation": "네, 갖고 있어요."
          },
          {
            "text": "Nein, ich muss noch einen Termin vereinbaren.",
            "pronunciation": "/naɪ̯n, ɪç mʊs nɔx ˈaɪ̯nən tɛʁˈmiːn fɛʁˈaɪ̯nbaʁən/",
            "translation": "아니요, 아직 약속을 잡아야 해요."
          },
          {
            "text": "Ich weiß nicht, ob ich das brauche.",
            "pronunciation": "/ɪç vaɪ̯s nɪçt, ɔp ɪç das ˈbraʊ̯xə/",
            "translation": "그게 필요한지 모르겠어요."
          }
        ],
        "answer": "Ja, die habe ich dabei.",
        "explanation": "경찰관은 필요한 서류가 있는지 묻습니다. '예, 갖고 있습니다'라는 긍정적인 대답은 이를 확인하고 프로세스가 계속되도록 합니다.",
        "grammar_point": "Akkusativobjekt ('die') als Ersatz für 'diese Dokumente' und Fragestellung mit Inversion."
      },
      {
        "id": "conv_rathaus_b1_W11_002",
        "situation": "새로운 직업을 가지려면 등록증이 필요하며, 절차에 대해서는 시민청에 문의하세요.",
        "situation_icon": "📝",
        "dialogue": [
          {
            "role": "Bürger/in",
            "text": "Guten Tag, ich bräuchte eine Meldebescheinigung.",
            "pronunciation": "/ˌɡuːtn̩ taːk, ɪç ˈbrøːçtə ˈaɪ̯nə ˈmɛldəbəˌʃaɪ̯nɪɡʊŋ/",
            "translation": "안녕하세요. 거주 증명서가 필요합니다.",
            "isQuestion": false
          },
          {
            "role": "Beamter/in",
            "text": "Ja, kein Problem. Haben Sie Ihren Personalausweis dabei?",
            "pronunciation": "/jaː, kaɪ̯n pʁoˈbleːm. ˈhabm̩ ziː ˈiːʁən pɛʁzoˈnaːlˌaʊ̯svaɪ̯s daˈbaɪ̯/",
            "translation": "예, 문제 없습니다. 신분증을 갖고 계시나요?",
            "isQuestion": false
          },
          {
