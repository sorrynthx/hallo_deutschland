        }
      ]
    },
    {
      "id": "gram_a1_007",
      "topic": "Personalpronomen im Nominativ (주격 인칭대명사)",
      "explanation": "독일어의 주격 인칭대명사는 문장의 주어 역할을 하며 '~은/는/이/가'로 해석됩니다. 대화 상대와의 관계에 따라 존칭(Sie)과 친칭(du, ihr)을 구별해서 사용해야 합니다.",
      "examples": [
        {
          "german": "Ich bin Schüler.",
          "korean": "나는 학생입니다.",
          "pronunciation": "이히 빈 쉴러"
        },
        {
          "german": "Woher kommen Sie?",
          "korean": "당신은 어디에서 오셨습니까?",
          "pronunciation": "보헤어 코멘 지?"
        }
      ],
      "conjugation_table": [
        {
          "pronoun": "1. Person Singular (1인칭 단수)",
          "form": "ich (나는)"
        },
        {
          "pronoun": "2. Person Singular (2인칭 단수)",
          "form": "du (너는)"
        },
        {
          "pronoun": "3. Person Singular (3인칭 단수)",
          "form": "er/sie/es (그는/그녀는/그것은)"
        },
        {
          "pronoun": "1. Person Plural (1인칭 복수)",
          "form": "wir (우리는)"
        },
        {
          "pronoun": "2. Person Plural (2인칭 복수)",
          "form": "ihr (너희들은)"
        },
        {
          "pronoun": "3. Person Plural & Formell (3복수 및 존칭)",
          "form": "sie/Sie (그들은/당신은)"
        }
      ]
    },
    {
      "id": "gram_a1_008",
      "topic": "Bestimmter und unbestimmter Artikel im Nominativ (정관사와 부정관사 1격)",
      "explanation": "독일어의 명사 앞에는 정관사(특정한 것)나 부정관사(불특정한 것 하나)가 옵니다. 주어로 쓰이는 1격(Nominativ)의 경우, 명사의 성(남성, 여성, 중성, 복수)에 따라 관사의 형태가 달라집니다.",
      "examples": [
        {
          "german": "Das ist ein Apfel. Der Apfel ist rot.",
          "korean": "이것은 사과(하나)입니다. 그 사과는 빨갛습니다.",
          "pronunciation": "다스 이스트 아인 압펠. 데어 압펠 이스트 로트."
        },
        {
          "german": "Das ist eine Frau. Die Frau ist nett.",
          "korean": "이 사람은 (어떤) 여자입니다. 그 여자는 친절합니다.",
          "pronunciation": "다스 이스트 아이네 프라우. 디 프라우 이스트 네트."
        }
      ],
      "conjugation_table": [
        {
          "pronoun": "Maskulin (남성)",
          "form": "der / ein"
        },
        {
          "pronoun": "Feminin (여성)",
          "form": "die / eine"
        },
        {
          "pronoun": "Neutral (중성)",
          "form": "das / ein"
        },
        {
          "pronoun": "Plural (복수)",
          "form": "die / - (없음)"
        }
      ]
    },
    {
      "id": "gram_a1_009",
      "topic": "Negation: 'nicht' und 'kein' (부정문: 'nicht'와 'kein')",
      "explanation": "독일어에서 부정문(아니다, 안 하다)을 만들 때는 주로 'nicht'나 'kein'을 사용합니다. 'kein'은 명사(부정관사가 붙는 명사나 관사가 없는 명사)를 부정할 때 사용하며, 'nicht'는 동사, 형용사, 부사 또는 특정한 명사(정관사가 있는 명사 등)를 부정할 때 사용합니다.",
      "examples": [
        {
          "german": "Ich habe kein Auto.",
          "korean": "나는 차가 없습니다.",
          "pronunciation": "이히 하베 카인 아우토"
        },
        {
          "german": "Das ist nicht mein Buch.",
          "korean": "이것은 내 책이 아닙니다.",
          "pronunciation": "다스 이스트 니히트 마인 부흐"
        }
      ],
      "conjugation_table": [
        {
          "pronoun": "Maskulin (남성)",
          "form": "kein (1격) / keinen (4격)"
        },
        {
          "pronoun": "Feminin (여성)",
          "form": "keine (1격) / keine (4격)"
        },
        {
          "pronoun": "Neutral (중성)",
          "form": "kein (1격) / kein (4격)"
        },
        {
          "pronoun": "Plural (복수)",
          "form": "keine (1격) / keine (4격)"
        }
      ]
    }
